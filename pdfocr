#!/usr/bin/env python3.11
import os
import sys
import argparse
import requests
import logging
import signal
from dotenv import load_dotenv
from requests.adapters import HTTPAdapter
from requests.packages.urllib3.util.retry import Retry

VERSION = "1.1.0"

# Load API key: ~/.env first (global), then local .env (override)
load_dotenv(os.path.expanduser("~/.env"))
load_dotenv()

HEADERS = {}  # populated in main() after API key is validated

logger = logging.getLogger(__name__)


def configure_logging(verbose=False, quiet=False):
    if quiet:
        level = logging.ERROR
    elif verbose:
        level = logging.DEBUG
    else:
        level = logging.WARNING
    logging.basicConfig(level=level, format='[%(levelname)s] %(message)s')


def signal_handler(sig, frame):
    logger.debug("Script interrupted.")
    sys.exit(1)


def create_session():
    session = requests.Session()
    retries = Retry(
        total=5,
        backoff_factor=0.3,
        status_forcelist=[429, 500, 502, 503, 504],
        allowed_methods=["HEAD", "GET", "OPTIONS", "POST"]
    )
    adapter = HTTPAdapter(max_retries=retries)
    session.mount('http://', adapter)
    session.mount('https://', adapter)
    return session


def upload_file(file_path, session):
    url = "https://api.mistral.ai/v1/files"
    data = {"purpose": "ocr"}
    with open(file_path, "rb") as file:
        files = {"file": (os.path.basename(file_path), file, "application/pdf")}
        response = session.post(url, headers=HEADERS, data=data, files=files)
        response.raise_for_status()
        return response.json()


def get_signed_url(file_id, session):
    url = f"https://api.mistral.ai/v1/files/{file_id}/url?expiry=24"
    response = session.get(url, headers=HEADERS)
    response.raise_for_status()
    return response.json().get("url")


def delete_file(file_id, session):
    url = f"https://api.mistral.ai/v1/files/{file_id}"
    try:
        response = session.delete(url, headers=HEADERS)
        response.raise_for_status()
        logger.debug(f"Deleted remote file {file_id}")
    except requests.exceptions.RequestException as e:
        logger.warning(f"Could not delete remote file {file_id}: {e}")


def process_ocr(signed_url, session, include_images=False):
    url = "https://api.mistral.ai/v1/ocr"
    payload = {
        "model": "mistral-ocr-latest",
        "document": {
            "type": "document_url",
            "document_url": signed_url
        },
        "include_image_base64": include_images
    }
    headers = {**HEADERS, "Content-Type": "application/json"}
    response = session.post(url, headers=headers, json=payload)
    response.raise_for_status()
    return response.json()


def derive_output_filename(input_file):
    base, ext = os.path.splitext(input_file)
    if ext.lower() == ".pdf":
        return f"{base}-ocr.md"
    return f"{input_file}-ocr.md"


def process_pdf(file_path, include_images=False):
    session = create_session()
    file_id = None
    try:
        logger.debug("Uploading file...")
        try:
            upload_response = upload_file(file_path, session)
            file_id = upload_response.get("id")
            if not file_id:
                logging.error("File upload failed: no file ID returned.")
                sys.exit(1)
            logger.debug(f"Uploaded file ID: {file_id}")
        except requests.exceptions.RequestException as e:
            logging.error(f"Error uploading file: {e}")
            sys.exit(1)

        logger.debug("Retrieving signed URL...")
        try:
            signed_url = get_signed_url(file_id, session)
            if not signed_url:
                logging.error("Failed to get signed URL.")
                sys.exit(1)
            logger.debug("Signed URL retrieved.")
        except requests.exceptions.RequestException as e:
            logging.error(f"Error retrieving signed URL: {e}")
            sys.exit(1)

        logger.debug("Processing OCR...")
        try:
            ocr_response = process_ocr(signed_url, session, include_images=include_images)
            pages = ocr_response.get("pages", [])
            if not pages:
                logging.error("No pages returned from OCR.")
                return ""
            logger.debug(f"OCR complete: {len(pages)} page(s) processed.")
            return "\n".join(page.get("markdown", "") for page in pages)
        except requests.exceptions.RequestException as e:
            logging.error(f"Error processing OCR: {e}")
            sys.exit(1)
    finally:
        if file_id:
            delete_file(file_id, session)


def main():
    parser = argparse.ArgumentParser(
        description="Extract text from a PDF using Mistral OCR and output as Markdown."
    )
    parser.add_argument("pdf_file", help="Path to the PDF file to process")
    parser.add_argument("-o", "--output", nargs="?", const="AUTO",
                        help="Output file. If flag given without value, derives name from input (input.pdf -> input-ocr.md). Default: stdout.")
    parser.add_argument("-v", "--verbose", action="store_true",
                        help="Enable verbose progress output.")
    parser.add_argument("-q", "--quiet", action="store_true",
                        help="Suppress all output except errors.")
    parser.add_argument("--images", action="store_true",
                        help="Include base64-encoded images in OCR output.")
    parser.add_argument("--version", action="version", version=f"pdfocr {VERSION}")
    args = parser.parse_args()

    configure_logging(verbose=args.verbose, quiet=args.quiet)

    api_key = os.getenv("MISTRAL_API_KEY")
    if not api_key:
        logging.error("MISTRAL_API_KEY environment variable not set")
        sys.exit(1)
    HEADERS["Authorization"] = f"Bearer {api_key}"
    HEADERS["Accept"] = "application/json"

    signal.signal(signal.SIGINT, signal_handler)
    signal.signal(signal.SIGTERM, signal_handler)

    if not os.path.isfile(args.pdf_file):
        logging.error(f"The file '{args.pdf_file}' does not exist.")
        sys.exit(1)

    ocr_text = process_pdf(args.pdf_file, include_images=args.images)

    if args.output is not None:
        out_filename = derive_output_filename(args.pdf_file) if args.output == "AUTO" else args.output
        try:
            with open(out_filename, "w", encoding="utf-8") as f:
                f.write(ocr_text)
            logger.debug(f"OCR output written to {out_filename}")
        except Exception as e:
            logging.error(f"Error writing to file {out_filename}: {e}")
            sys.exit(1)
    else:
        print(ocr_text)


if __name__ == "__main__":
    main()
