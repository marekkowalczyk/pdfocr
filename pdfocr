#!/usr/bin/env python3
import os
import sys

# Re-exec under this project's own venv interpreter, resolved from this
# file's real location so the script works regardless of where it's
# cloned or what venv (if any) is active in the caller's shell.
_venv_dir = os.path.join(os.path.dirname(os.path.realpath(__file__)), '.venv')
_venv_python = os.path.join(_venv_dir, 'bin', 'python3')
if os.path.exists(_venv_python) and os.path.realpath(sys.prefix) != os.path.realpath(_venv_dir):
    os.execv(_venv_python, [_venv_python] + sys.argv)

import argparse
import requests
import logging
import signal
import tempfile
from dotenv import load_dotenv
from requests.adapters import HTTPAdapter
from requests.packages.urllib3.util.retry import Retry

VERSION = "1.2.0"

# sysexits.h-style exit codes, so callers can branch on failure class
EX_OK = 0
EX_USAGE = 64
EX_NOINPUT = 66
EX_UNAVAILABLE = 69
EX_CANTCREAT = 73
EX_PROTOCOL = 76
EX_CONFIG = 78

# Load API key: ~/.env first (global), then local .env (override)
load_dotenv(os.path.expanduser("~/.env"))
load_dotenv()

HEADERS = {}  # populated in main() after API key is validated

logger = logging.getLogger(__name__)


class OcrError(Exception):
    def __init__(self, message, code):
        super().__init__(message)
        self.code = code


def configure_logging(verbose=False, quiet=False):
    if quiet:
        level = logging.ERROR
    elif verbose:
        level = logging.DEBUG
    else:
        level = logging.WARNING
    logging.basicConfig(level=level, format='[%(levelname)s] %(message)s')


def signal_handler(sig, frame):
    logger.debug("Script interrupted.")
    sys.exit(128 + sig)


def create_session():
    session = requests.Session()
    retries = Retry(
        total=5,
        backoff_factor=0.3,
        status_forcelist=[429, 500, 502, 503, 504],
        allowed_methods=["HEAD", "GET", "OPTIONS", "POST"]
    )
    adapter = HTTPAdapter(max_retries=retries)
    session.mount('http://', adapter)
    session.mount('https://', adapter)
    return session


def upload_file(file_path, session):
    url = "https://api.mistral.ai/v1/files"
    data = {"purpose": "ocr"}
    with open(file_path, "rb") as file:
        files = {"file": (os.path.basename(file_path), file, "application/pdf")}
        response = session.post(url, headers=HEADERS, data=data, files=files)
        response.raise_for_status()
        return response.json()


def get_signed_url(file_id, session):
    url = f"https://api.mistral.ai/v1/files/{file_id}/url?expiry=24"
    response = session.get(url, headers=HEADERS)
    response.raise_for_status()
    return response.json().get("url")


def delete_file(file_id, session):
    url = f"https://api.mistral.ai/v1/files/{file_id}"
    try:
        response = session.delete(url, headers=HEADERS)
        response.raise_for_status()
        logger.debug(f"Deleted remote file {file_id}")
    except requests.exceptions.RequestException as e:
        logger.warning(f"Could not delete remote file {file_id}: {e}")


def process_ocr(signed_url, session, include_images=False):
    url = "https://api.mistral.ai/v1/ocr"
    payload = {
        "model": "mistral-ocr-latest",
        "document": {
            "type": "document_url",
            "document_url": signed_url
        },
        "include_image_base64": include_images
    }
    headers = {**HEADERS, "Content-Type": "application/json"}
    response = session.post(url, headers=headers, json=payload)
    response.raise_for_status()
    return response.json()


def derive_output_filename(input_file):
    if input_file == "-":
        return "stdin-ocr.md"
    base, ext = os.path.splitext(input_file)
    if ext.lower() == ".pdf":
        return f"{base}-ocr.md"
    return f"{input_file}-ocr.md"


def process_pdf(file_path, include_images=False):
    session = create_session()
    file_id = None
    try:
        logger.debug("Uploading file...")
        try:
            upload_response = upload_file(file_path, session)
            file_id = upload_response.get("id")
            if not file_id:
                raise OcrError("File upload failed: no file ID returned.", EX_PROTOCOL)
            logger.debug(f"Uploaded file ID: {file_id}")
        except requests.exceptions.RequestException as e:
            raise OcrError(f"Error uploading file: {e}", EX_UNAVAILABLE)

        logger.debug("Retrieving signed URL...")
        try:
            signed_url = get_signed_url(file_id, session)
            if not signed_url:
                raise OcrError("Failed to get signed URL.", EX_PROTOCOL)
            logger.debug("Signed URL retrieved.")
        except requests.exceptions.RequestException as e:
            raise OcrError(f"Error retrieving signed URL: {e}", EX_UNAVAILABLE)

        logger.debug("Processing OCR...")
        try:
            ocr_response = process_ocr(signed_url, session, include_images=include_images)
            pages = ocr_response.get("pages", [])
            if not pages:
                logging.error("No pages returned from OCR.")
                return ""
            logger.debug(f"OCR complete: {len(pages)} page(s) processed.")
            return "\n".join(page.get("markdown", "") for page in pages)
        except requests.exceptions.RequestException as e:
            raise OcrError(f"Error processing OCR: {e}", EX_UNAVAILABLE)
    finally:
        if file_id:
            delete_file(file_id, session)


def resolve_input(pdf_file):
    """Returns (path_to_read, cleanup_fn). For '-', buffers stdin to a temp file."""
    if pdf_file != "-":
        return pdf_file, None
    with tempfile.NamedTemporaryFile(suffix=".pdf", delete=False) as tmp:
        tmp.write(sys.stdin.buffer.read())
        tmp_path = tmp.name
    return tmp_path, lambda: os.unlink(tmp_path)


def main():
    parser = argparse.ArgumentParser(
        description="Extract text from a PDF using Mistral OCR and output as Markdown."
    )
    parser.add_argument("pdf_files", nargs="+", metavar="pdf_file",
                        help="Path to the PDF file(s) to process. Use '-' to read a single PDF from stdin.")
    parser.add_argument("-o", "--output", nargs="?", const="AUTO",
                        help="Output file. If flag given without value, derives name from input (input.pdf -> input-ocr.md). Default: stdout.")
    parser.add_argument("-v", "--verbose", action="store_true",
                        help="Enable verbose progress output.")
    parser.add_argument("-q", "--quiet", action="store_true",
                        help="Suppress all output except errors.")
    parser.add_argument("--images", action="store_true",
                        help="Include base64-encoded images in OCR output.")
    parser.add_argument("--version", action="version", version=f"pdfocr {VERSION}")
    args = parser.parse_args()

    configure_logging(verbose=args.verbose, quiet=args.quiet)

    if len(args.pdf_files) > 1 and args.output not in (None, "AUTO"):
        logging.error("Cannot write multiple input files to a single explicit -o path.")
        sys.exit(EX_USAGE)

    if args.pdf_files.count("-") > 1:
        logging.error("stdin ('-') can only be used once.")
        sys.exit(EX_USAGE)

    api_key = os.getenv("MISTRAL_API_KEY")
    if not api_key:
        logging.error("MISTRAL_API_KEY environment variable not set")
        sys.exit(EX_CONFIG)
    HEADERS["Authorization"] = f"Bearer {api_key}"
    HEADERS["Accept"] = "application/json"

    signal.signal(signal.SIGINT, signal_handler)
    signal.signal(signal.SIGTERM, signal_handler)

    exit_code = EX_OK
    for pdf_file in args.pdf_files:
        if pdf_file != "-" and not os.path.isfile(pdf_file):
            logging.error(f"The file '{pdf_file}' does not exist.")
            exit_code = EX_NOINPUT if len(args.pdf_files) == 1 else 1
            continue

        read_path, cleanup = resolve_input(pdf_file)
        try:
            ocr_text = process_pdf(read_path, include_images=args.images)
        except OcrError as e:
            logging.error(str(e))
            exit_code = e.code if len(args.pdf_files) == 1 else 1
            continue
        finally:
            if cleanup:
                cleanup()

        if args.output is not None:
            out_filename = derive_output_filename(pdf_file) if args.output == "AUTO" else args.output
            try:
                with open(out_filename, "w", encoding="utf-8") as f:
                    f.write(ocr_text)
                logger.debug(f"OCR output written to {out_filename}")
            except OSError as e:
                logging.error(f"Error writing to file {out_filename}: {e}")
                exit_code = EX_CANTCREAT if len(args.pdf_files) == 1 else 1
                continue
        else:
            print(ocr_text)

    sys.exit(exit_code)


if __name__ == "__main__":
    main()
